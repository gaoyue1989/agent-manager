# Agent Manager .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
codegen/venv/
codegen/test/output/

# Go
backend/vendor/
*.exe
*.dll
*.so
*.dylib
backend/bin/
backend/server

# Node (E2E only)
e2e/node_modules/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
*.tar

# Environment
.env
.env.local
.env.*.local
.env.test

# Logs
*.log

# Kind / K8s
sandbox/manifest.yaml
sandbox/extensions.yaml
docs/kind-config.yaml

# Temp
tmp/
temp/
*.tmp

# Secrets (keep API keys out of repo)
!codegen/schema/agent_config.json

# Screenshots
e2e/screenshots/
*.png

# E2E test scripts
e2e/screenshot.js
