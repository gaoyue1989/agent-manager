# LLM 配置 (必填)
LLM_API_KEY=your_api_key_here
LLM_MODEL_ID=your_model_id_here
LLM_BASE_URL=https://api.example.com/v1
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# 配置目录路径
AGENT_CONFIG_DIR=/config

# 服务端口
SERVER_PORT=8100
SERVER_HOST=0.0.0.0

# MCP（可选）
# MCP_FILESYSTEM_URL=http://localhost:8811/sse

# MySQL Checkpoint 持久化 (可选)
CHECKPOINT_MYSQL_DSN=mysql+asyncmy://agent_manager:Agent%40Manager2026@127.0.0.1:3307/agent_manager_test
