{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentConfig",
  "type": "object",
  "required": ["name", "description", "model", "system_prompt"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Agent 名称"
    },
    "description": {
      "type": "string",
      "description": "Agent 描述"
    },
    "model": {
      "type": "string",
      "description": "LLM 模型 ID",
      "default": "qwen3.6-plus"
    },
    "model_endpoint": {
      "type": "string",
      "description": "LLM API 端点",
      "default": "https://dashscope.aliyuncs.com/compatible-mode/v1"
    },
    "api_key": {
      "type": "string",
      "description": "LLM API Key",
      "default": "sk-****"
    },
    "system_prompt": {
      "type": "string",
      "description": "系统提示词"
    },
    "enabled_tools": {
      "type": "array",
      "items": {"type": "string"},
      "description": "启用的 DeepAgents 内置工具列表",
      "default": ["write_todos", "ls", "read_file", "write_file", "edit_file", "glob", "grep", "task"]
    },
    "excluded_tools": {
      "type": "array",
      "items": {"type": "string"},
      "description": "禁用的工具列表，优先级高于 enabled_tools",
      "default": []
    },
    "mcp_config": {
      "type": "object",
      "properties": {
        "url": {"type": "string", "description": "MCP Server 地址"},
        "transport": {"type": "string", "enum": ["sse", "stdio"], "description": "传输协议", "default": "sse"},
        "headers": {
          "type": "object",
          "additionalProperties": {"type": "string"},
          "description": "自定义请求头"
        }
      },
      "description": "MCP (Model Context Protocol) 配置"
    },
    "sub_agents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "description": {"type": "string"},
          "system_prompt": {"type": "string"}
        }
      },
      "default": [],
      "description": "子 Agent 定义"
    },
    "memory": {
      "type": "boolean",
      "description": "是否启用记忆",
      "default": true
    },
    "max_iterations": {
      "type": "integer",
      "description": "最大迭代次数",
      "default": 50
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "description": "Skill 名称"},
          "description": {"type": "string", "description": "Skill 描述"},
          "path": {"type": "string", "description": "后端存储路径"},
          "license": {"type": "string", "description": "许可证"},
          "compatibility": {"type": "string", "description": "兼容性"},
          "allowed_tools": {
            "type": "array",
            "items": {"type": "string"},
            "description": "推荐工具"
          }
        }
      },
      "description": "上传的 Skill 元数据列表",
      "default": []
    }
  }
}
